# Copy to /etc/portfolio-mail.env on the droplet (chmod 600 root:root or root:deploy).
#
# Mail uses Gmail API only (HTTPS). One-time on your PC:
#   pip install -r requirements.txt
#   python setup_gmail_oauth.py /path/to/Desktop-client-*.json
# Paste GMAIL_* below. In Google Cloud (manual): enable Gmail API, OAuth consent with scope
# https://www.googleapis.com/auth/gmail.send , Desktop OAuth client JSON.
#
MAIL_FROM_EMAIL=payam.dehkordy@gmail.com
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=
#
# Comma-separated allowlist for browser Origin checks + CORS
MAIL_ALLOWED_ORIGINS=https://www.payam-dehkordy.com,https://payam-dehkordy.com
