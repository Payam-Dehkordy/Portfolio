# Copy to /etc/portfolio-mail.env on the droplet (chmod 600 root:root or root:deploy).
# Gmail: Google Account → Security → 2-Step Verification → App passwords → generate for “Mail”.
#
MAIL_FROM_EMAIL=payam.dehkordy@gmail.com
MAIL_SMTP_USER=payam.dehkordy@gmail.com
MAIL_SMTP_APP_PASSWORD=
MAIL_SMTP_HOST=smtp.gmail.com
MAIL_SMTP_PORT=587
# Comma-separated allowlist for browser Origin checks + CORS
MAIL_ALLOWED_ORIGINS=https://www.payam-dehkordy.com,https://payam-dehkordy.com
