# Copy to server as /etc/portfolio-mail.env (never commit real secrets).
# Every variable portfolio-mail reads is listed below (style aligned with ChiKoja/.env.example).
#
# Mirror this template on the droplet after deploy updates /opt/portfolio-mail — see Droplet
# docs SERVER_CONVENTIONS.md § Environment files; setup steps PORTFOLIO_HOSTING.md § Phase 2.
# Then: sudo systemctl restart portfolio-mail

# =============================================================================
# SECRETS — fill on the server only; never commit or paste publicly
# =============================================================================

GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=

# =============================================================================
# NON-SECRET CONFIG — safe to copy from this example when asking for help
# =============================================================================

# Must match the Google account you authorized with setup_gmail_oauth.py (visible From:/To:).
MAIL_FROM_EMAIL=payam.dehkordy@gmail.com

# Comma-separated HTTPS origins for CORS + Origin check on POST /api/mail (no spaces).
MAIL_ALLOWED_ORIGINS=https://www.payam-dehkordy.com,https://payam-dehkordy.com
