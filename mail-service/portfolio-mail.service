[Unit]
Description=Portfolio site mail API (Gmail SMTP, localhost only)
After=network.target

[Service]
Type=simple
User=deploy
Group=deploy
WorkingDirectory=/opt/portfolio-mail
EnvironmentFile=-/etc/portfolio-mail.env
ExecStart=/opt/portfolio-mail/venv/bin/uvicorn main:app --host 127.0.0.1 --port 8791 --proxy-headers
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
